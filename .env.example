# ============================================================
# EntrezJS Queen Configuration (.env)
# ============================================================
# Copy this file to .env for QUEEN servers
# Queens need: unique codename, API keys, webhook, SMTP
# Bees can run with defaults or minimal config

# ============================================================
# Required for QUEEN: Server Codename
# ============================================================
# Must be unique, lowercase letters and numbers only
SERVER_CODE_NAME=queen01

# ============================================================
# Required for QUEEN: Server Role
# ============================================================
SERVER_ROLE=queen

# ============================================================
# Server Configuration
# ============================================================
PORT=8080
SERVER_URL=http://localhost:8080

# ============================================================
# Sensitive: NCBI API Keys (for higher rate limits)
# Multiple keys separated by commas
# QUEEN ONLY - stores developer API keys
# ============================================================
ENTREZ_API_KEYS=key1,key2,key3

# ============================================================
# Sensitive: Slack Webhook (for daily trending notifications)
# QUEEN ONLY - sends trending data to Slack
# ============================================================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx

# ============================================================
# Sensitive: Email (SMTP) Configuration
# QUEEN ONLY - for developer registration verification
# ============================================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-password

# ============================================================
# Distributed System (Queen/Bee)
# ============================================================
# For bee: Queen server address (set on BEE servers)
# QUEEN_HOST=192.168.1.100
# QUEEN_PORT=8080

# For second queen: First queen address
# FIRST_QUEEN_HOST=192.168.1.100
# FIRST_QUEEN_PORT=8080
